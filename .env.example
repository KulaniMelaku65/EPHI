# EPHI Training System Configuration

# Database Configuration
# For SQLite (Development): DB_TYPE=sqlite
# For PostgreSQL (Production): DB_TYPE=postgres

DB_TYPE=sqlite

# PostgreSQL Configuration (only needed if DB_TYPE=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ephi_training
POSTGRES_USER=ephi_user
POSTGRES_PASSWORD=your_secure_password_here

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-random-secret-key-here-change-in-production

# Email Configuration (Optional - for email authentication)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG=False
