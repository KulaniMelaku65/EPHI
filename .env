# ===== EPHI TRAINING SYSTEM CONFIGURATION =====
# Copy this file and fill in your actual values
# NEVER commit this file to git (add to .gitignore)

# ===== DATABASE CONFIGURATION =====
DB_TYPE=sqlite
# For PostgreSQL: DB_TYPE=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ephi_training
# POSTGRES_USER=ephi_user
# POSTGRES_PASSWORD=your_password_here

# ===== FLASK SECURITY =====
# CRITICAL: Generate a random SECRET_KEY
# Run: python -c "import secrets; print(secrets.token_hex(32))"
# Replace with the output:
SECRET_KEY=your-random-secret-key-here-at-least-32-characters

FLASK_ENV=production
DEBUG=False

# ===== EMAIL CONFIGURATION (Gmail) =====
# Follow instructions below to enable real email sending:
# 1. Go to myaccount.google.com → Security
# 2. Enable 2-Factor Authentication (if not already done)
# 3. Create "App password" for "Mail" and "Windows Computer"
# 4. Copy the 16-character password below

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password-here

# Example (DO NOT USE THIS):
# SMTP_EMAIL=kulanimelaku@gmail.com
# SMTP_PASSWORD=abcd efgh ijkl mnop

# ===== CORS CONFIGURATION (Security) =====
# List your domain(s) here, comma-separated
# Example: https://ephi-training.com,https://www.ephi-training.com
# For local development: http://localhost:5000
CORS_ORIGINS=http://localhost:5000

# ===== SERVER CONFIGURATION =====
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
